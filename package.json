{
  "name": "@powerhousedao/vetra-builder-package",
  "description": "Vetra document models, editors, and processors for Powerhouse",
  "version": "5.2.0-staging.13",
  "license": "AGPL-3.0-only",
  "type": "module",
  "files": [
    "/dist"
  ],
  "release": {
    "branches": [
      "main",
      {
        "name": "staging",
        "prerelease": "staging"
      },
      {
        "name": "dev",
        "prerelease": "dev"
      }
    ],
    "plugins": [
      "@semantic-release/changelog",
      "@semantic-release/git",
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/github"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/browser/index.js",
      "node": "./dist/node/index.mjs"
    },
    "./reactor": {
      "types": "./dist/types/reactor/index.d.ts",
      "browser": "./dist/browser/reactor/index.js"
    },
    "./document-models": {
      "types": "./dist/types/document-models/index.d.ts",
      "browser": "./dist/browser/document-models/index.js",
      "node": "./dist/node/document-models/index.mjs"
    },
    "./document-models/*": {
      "types": "./dist/types/document-models/*/index.d.ts",
      "browser": "./dist/browser/document-models/*/index.js",
      "node": "./dist/node/document-models/*/index.mjs"
    },
    "./editors": {
      "types": "./dist/types/editors/index.d.ts",
      "browser": "./dist/browser/editors/index.js",
      "node": "./dist/node/editors/index.mjs"
    },
    "./editors/*": {
      "types": "./dist/types/editors/*/editor.d.ts",
      "browser": "./dist/browser/editors/*/editor.js",
      "node": "./dist/node/editors/*/editor.mjs"
    },
    "./subgraphs": {
      "types": "./dist/types/subgraphs/index.d.ts",
      "browser": "./dist/browser/subgraphs/index.js",
      "node": "./dist/node/subgraphs/index.mjs"
    },
    "./processors": {
      "types": "./dist/types/processors/index.d.ts",
      "browser": "./dist/browser/processors/index.js",
      "node": "./dist/node/processors/index.mjs"
    },
    "./manifest": "./dist/powerhouse.manifest.json",
    "./style.css": "./dist/style.css"
  },
  "scripts": {
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --type-aware --type-check --fix",
    "build:tsc": "tsc",
    "build:tsc:watch": "tsc --watch",
    "build:css": "npx @tailwindcss/cli -i ./style.css -o ./dist/style.css",
    "build:css:watch": "npx @tailwindcss/cli -i ./style.css -o ./dist/style.css --watch",
    "build": "ph-cli build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "generate": "ph-cli generate",
    "connect": "ph-cli connect",
    "reactor": "ph-cli reactor",
    "service": "ph-cli service",
    "service-startup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-startup.sh",
    "service-unstartup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-unstartup.sh",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "tailwind": "npx @tailwindcss/cli -i ./style.css -o ./dist/style.css",
    "check-circular-imports": "npx dpdm -T ./index.ts",
    "vetra": "ph-cli vetra",
    "migrate": "ph-cli migrate",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.3.15",
    "@electric-sql/pglite-tools": "0.2.20",
    "@openfeature/core": "^1.9.1",
    "@powerhousedao/analytics-engine-core": "6.2.0-dev.45",
    "@powerhousedao/builder-tools": "6.2.0-dev.45",
    "@powerhousedao/codegen": "6.2.0-dev.45",
    "@powerhousedao/common": "6.2.0-dev.45",
    "@powerhousedao/config": "6.2.0-dev.45",
    "@powerhousedao/connect": "6.2.0-dev.45",
    "@powerhousedao/design-system": "6.2.0-dev.45",
    "@powerhousedao/document-engineering": "1.40.5",
    "@powerhousedao/ph-cli": "6.2.0-dev.45",
    "@powerhousedao/reactor": "6.2.0-dev.45",
    "@powerhousedao/reactor-api": "6.2.0-dev.45",
    "@powerhousedao/reactor-browser": "6.2.0-dev.45",
    "@powerhousedao/reactor-local": "staging",
    "@powerhousedao/scalars": "staging",
    "@powerhousedao/shared": "6.2.0-dev.45",
    "@powerhousedao/switchboard": "6.2.0-dev.45",
    "@powerhousedao/vetra": "6.2.0-dev.45",
    "@renown/sdk": "6.2.0-dev.45",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/react": "^16.3.0",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.1",
    "adm-zip": "^0.5.16",
    "document-drive": "staging",
    "document-model": "6.2.0-dev.45",
    "graphql": "^16.10.0",
    "graphql-request": "^7.2.0",
    "graphql-tag": "2.12.6",
    "kysely": "^0.28.7",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.6",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "package-manager-detector": "^0.2.8",
    "pm2": "^5.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "semantic-release": "^25.0.2",
    "storybook": "^8.6.14",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.9.3",
    "uuid": "^11.1.0",
    "vite": "^8.0.10",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@powerhousedao/reactor-browser": "6.2.0-dev.45",
    "document-model": "6.2.0-dev.45",
    "graphql": "^16",
    "graphql-tag": "^2",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4"
  },
  "readme": "ERROR: No README data found!",
  "sideEffects": false
}
