{
  "name": "@powerhousedao/vetra-builder-package",
  "description": "Vetra document models, editors, and processors for Powerhouse",
  "version": "5.2.0-dev.24",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/powerhouse-inc/vetra-builder-package.git"
  },
  "type": "module",
  "files": [
    "/dist"
  ],
  "release": {
    "branches": [
      "main",
      {
        "name": "staging",
        "prerelease": "staging"
      },
      {
        "name": "dev",
        "prerelease": "dev"
      }
    ],
    "plugins": [
      "@semantic-release/changelog",
      "@semantic-release/git",
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/github"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./document-models": {
      "types": "./dist/document-models/index.d.ts",
      "default": "./dist/document-models/index.js"
    },
    "./editors": {
      "types": "./dist/editors/index.d.ts",
      "default": "./dist/editors/index.js"
    },
    "./subgraphs": {
      "types": "./dist/subgraphs/index.d.ts",
      "default": "./dist/subgraphs/index.js"
    },
    "./processors": {
      "types": "./dist/processors/index.d.ts",
      "default": "./dist/processors/index.js"
    },
    "./manifest": {
      "default": "./dist/powerhouse.manifest.json"
    },
    "./style.css": "./dist/style.css",
    "./document-models/*": {
      "types": "./dist/document-models/*/index.d.ts",
      "default": "./dist/document-models/*/index.js"
    },
    "./editors/*": {
      "types": "./dist/editors/*/index.d.ts",
      "default": "./dist/editors/*/index.js"
    }
  },
  "scripts": {
    "lint": "eslint --config eslint.config.js --cache --cache-strategy content",
    "lint:fix": "npm run lint -- --fix",
    "build:tsc": "tsc",
    "build:tsc:watch": "tsc --watch",
    "build:css": "npx @tailwindcss/cli -i ./style.css -o ./dist/style.css",
    "build:css:watch": "npx @tailwindcss/cli -i ./style.css -o ./dist/style.css --watch",
    "build": "npm run tsc && npm run tailwind",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "generate": "ph-cli generate",
    "connect": "ph-cli connect",
    "reactor": "ph-cli reactor",
    "service": "ph-cli service",
    "service-startup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-startup.sh",
    "service-unstartup": "bash ./node_modules/@powerhousedao/ph-cli/dist/scripts/service-unstartup.sh",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "tailwind": "npx @tailwindcss/cli -i ./style.css -o ./dist/style.css",
    "check-circular-imports": "npx dpdm -T ./index.ts",
    "vetra": "ph-cli vetra",
    "migrate": "ph-cli migrate"
  },
  "dependencies": {
    "@powerhousedao/builder-tools": "6.0.0-dev.101",
    "@powerhousedao/common": "6.0.0-dev.101",
    "@powerhousedao/connect": "6.0.0-dev.101",
    "@powerhousedao/design-system": "6.0.0-dev.101",
    "@powerhousedao/document-engineering": "^1.40.1",
    "@powerhousedao/vetra-cloud-package": "0.0.0-dev.11",
    "@renown/sdk": "dev",
    "cmd-ts": "^0.15.0",
    "document-model": "6.0.0-dev.101",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "kysely": "^0.28.14",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.7",
    "uuid": "^11.1.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "@eslint/js": "^9.39.4",
    "@openfeature/core": "^1.9.2",
    "@powerhousedao/analytics-engine-core": "6.0.0-dev.101",
    "@powerhousedao/codegen": "6.0.0-dev.101",
    "@powerhousedao/config": "6.0.0-dev.101",
    "@powerhousedao/ph-cli": "6.0.0-dev.101",
    "@powerhousedao/reactor": "6.0.0-dev.101",
    "@powerhousedao/reactor-api": "6.0.0-dev.101",
    "@powerhousedao/reactor-browser": "6.0.0-dev.101",
    "@powerhousedao/reactor-local": "6.0.0-dev.101",
    "@powerhousedao/scalars": "dev",
    "@powerhousedao/switchboard": "6.0.0-dev.101",
    "@powerhousedao/vetra": "6.0.0-dev.101",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "adm-zip": "^0.5.16",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "package-manager-detector": "^0.2.11",
    "pm2": "^5.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semantic-release": "^25.0.3",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.4.1",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4"
    },
    "patchedDependencies": {
      "@powerhousedao/codegen@6.0.0-dev.101": "patches/@powerhousedao__codegen@6.0.0-dev.101.patch"
    }
  },
  "readme": "ERROR: No README data found!",
  "bugs": {
    "url": "https://github.com/powerhouse-inc/vetra-builder-package/issues"
  },
  "homepage": "https://github.com/powerhouse-inc/vetra-builder-package#readme"
}
